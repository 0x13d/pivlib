{
  "name": "pivlib-cli",
  "version": "0.1.0",
  "description": "Cross-platform CLI for inspecting and transcoding PIV/PKI files. Ships a native Rust binary per platform.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Ari Ugwu <ari@thirteendelta.com>",
  "homepage": "https://github.com/0x13d/pivlib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x13d/pivlib.git",
    "directory": "packages/pivlib-cli"
  },
  "bugs": {
    "url": "https://github.com/0x13d/pivlib/issues"
  },
  "keywords": [
    "piv",
    "x509",
    "pkcs7",
    "pkcs12",
    "cbeff",
    "cli"
  ],
  "bin": {
