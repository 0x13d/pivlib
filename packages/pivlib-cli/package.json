  },
  "files": [
    "bin",
    "README.md",
    "LICENSE.md"
  ],
  "optionalDependencies": {
    "pivlib-cli-darwin-x64": "0.1.0",
    "pivlib-cli-darwin-arm64": "0.1.0",
    "pivlib-cli-linux-x64-gnu": "0.1.0",
    "pivlib-cli-linux-arm64-gnu": "0.1.0",
    "pivlib-cli-win32-x64-msvc": "0.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
