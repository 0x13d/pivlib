{
  "name": "pivlib",
  "version": "0.1.0",
  "description": "PIV/PKI toolkit: detect any encoding (DER, PEM, base64-of-DER, PKCS#7, PKCS#12), parse + classify X.509 certs with PIV key-role detection, decode CHUID/CCC/SecurityObject, and encode INCITS 378/381/385 biometric records into CBEFF. Runs in Node and the browser via WASM.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Ari Ugwu <ari@thirteendelta.com>",
  "homepage": "https://github.com/0x13d/pivlib#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x13d/pivlib.git",
    "directory": "packages/pivlib"
  },
  "bugs": {
    "url": "https://github.com/0x13d/pivlib/issues"
  },
  "keywords": [
    "piv",
    "x509",
    "pkcs7",
    "pkcs12",
    "fips-201",
    "cbeff",
    "incits",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.node.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wasm",
    "wasm-node",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build:wasm": "cd ../.. && make wasm wasm-node",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
